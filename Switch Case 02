                                                console.log("Fecha o terminal")
                                                break;
                                                default:
                                                console.log("Comando não reconhecido no Windows")
    }
}else if (so === 2){
    console.log("Comandos Linux")
    let opcao1 = prompt("Digite os comandos Linux")
    switch (opcao1){
        case "ls":
            console.log("O comando ls serve para listar arquivos")
            break;
            case "cd":
                console.log("Serve para navegar entre pastas")
                break;
                case "pwd":
                    console.log("Mostra o diretório atual")
                    break;
                    case "mkdir":
                        console.log("Serve para criar uma pasta")
