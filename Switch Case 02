if (so === 1) {
    console.log("Comandos Windows")
    
    let opcao = prompt("Digite o comando CMD: ")
    switch(opcao){
        case "cd":
            console.log ("O comenado CD serve para entrar no diretório")
            break;
            case "mkdir":
                console.log("O comando mkdir serve para criar diretórios")
                break;
                case "dir":
                    console.log("Lista arquivos e pastas do diretório atual")
                    break;
                    case "cd..":
                        console.log("Volta uma pasta")
                        break;
                        case "rmdir":
                            console.log("Remove uma pasta")
                            break;
                            case "cls":
                                console.log("Limpa a tela")
                                break;
                                case "copy":
                                    console.log("Copia arquivos")
                                    break;
                                    case "move":
                                        console.log("Move arquivos")
                                        break;
                                        case "del":
                                            console.log("Apaga arquivos")
                                            break;
